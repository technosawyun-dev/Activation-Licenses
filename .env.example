# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/licensedb

# Random secret for signing session cookies — run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-hex-string

# Fernet key for encrypting private keys at rest — run: python generate_key.py
ENCRYPTION_KEY=change-me-run-generate_key.py-to-get-this

# First admin user (auto-created on first startup if no admins exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Base URL of THIS server (used to build activation links shown in dashboard)
BASE_URL=https://your-server.com

# Mark the session cookie HTTPS-only. Set to true once this is served over real
# HTTPS (e.g. behind Caddy) — leave false for local http:// development, since
# browsers refuse to send a Secure cookie back over plain HTTP.
SESSION_HTTPS_ONLY=false

# App name shown in dashboard header
APP_NAME=Saw Yun License Server

# PostgreSQL password (used by docker-compose for the db container)
POSTGRES_PASSWORD=change-me-strong-db-password
